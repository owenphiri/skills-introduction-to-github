# SafeGirl EduTrack — environment configuration
# Copy to .env and fill in for a real deployment. The app runs with NONE of
# these set (mock SMS, local SQLite) — they are only needed to go live.

# --- Server ---
PORT=3000
HOST=0.0.0.0
# Path to the SQLite database file (use an encrypted volume in production).
SEWSMS_DB=./data/sewsms.db
# Session lifetime in milliseconds (default 12h).
SESSION_TTL_MS=43200000

# --- SMS / WhatsApp gateway ---
# Provider: mock | africastalking | http
MESSAGING_PROVIDER=mock
SMS_SENDER_ID=SAFEGIRL

# Africa's Talking (set MESSAGING_PROVIDER=africastalking)
AT_USERNAME=
AT_API_KEY=
# AT_API_URL defaults to the live endpoint; use the sandbox URL for testing.
# AT_API_URL=https://api.sandbox.africastalking.com/version1/messaging

# Generic HTTP gateway (set MESSAGING_PROVIDER=http) — e.g. a Zamtel/MTN/Airtel bus
SMS_API_URL=
SMS_API_KEY=

# Shared secret the aggregator must present on delivery-report webhooks
# (sent as the X-Webhook-Secret header or ?token= query param).
SMS_WEBHOOK_SECRET=

# --- Counseling reminders ---
# How often the reminder dispatcher runs, in milliseconds (default hourly).
REMINDER_INTERVAL_MS=3600000

# --- Risk engine thresholds (policy tuning) ---
RISK_MEDIUM=30
RISK_HIGH=60
RISK_CONSECUTIVE=3
RISK_MONTHLY=5
