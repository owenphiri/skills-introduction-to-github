# HardWare Plus POS — Environment Configuration
# Copy this file to .env and fill in values for your deployment.
# The app runs fine without any of these set (uses sensible defaults).

# ── Server ────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0

# Path to the SQLite database (use an encrypted volume in production).
POS_DB=./data/pos.db

# Session lifetime in ms (default 8 hours = 28800000).
SESSION_TTL_MS=28800000

# ── Domain (Docker / Caddy) ──────────────────────────────────────
# Point your DNS A record at the server, then set this.
DOMAIN=pos.yourdomain.com

# ── Business Details ─────────────────────────────────────────────
BUSINESS_NAME=HardWare Plus
BUSINESS_ADDRESS=23 Cairo Road, Lusaka, Zambia
BUSINESS_PHONE=+260 211 234 567
BUSINESS_EMAIL=sales@hardwareplus.co.zm
BUSINESS_TAGLINE=Your Complete Hardware Solution
RECEIPT_FOOTER=Thank you for your business!

# ── Tax & Currency ────────────────────────────────────────────────
VAT_RATE=16
VAT_NAME=VAT
TIN_NUMBER=TIN-0000000000
VAT_NUMBER=VAT-000000000
CURRENCY=ZMW
CURRENCY_SYMBOL=K

# ── POS Options ───────────────────────────────────────────────────
RECEIPT_PREFIX=RCP
PO_PREFIX=PO
CUST_PREFIX=CUST
