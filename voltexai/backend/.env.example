# ============================================================
# VoltexAI - Environment Variables Template
# Copy to .env and fill in. Never commit .env to git.
# ============================================================

# --- App ---
ENVIRONMENT=development
BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# --- Database ---
# Dev: sqlite. Prod: postgresql+psycopg://user:pass@host:5432/voltexai
DATABASE_URL=sqlite:///./voltexai.db

# --- Auth ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=replace-with-48-char-random-string-from-secrets-module

# --- Anthropic (Claude API) ---
ANTHROPIC_API_KEY=sk-ant-api03-XXXXXXXXXXXXXXXXXXXXXX
CLAUDE_MODEL=claude-sonnet-4-5

# --- Market data feed ---
# Leave keys blank to use the built-in simulated feed (app stays fully functional).
# auto = use a real vendor where a key is set, else Binance (crypto), else synthetic.
MARKET_DATA_PROVIDER=auto
# Twelve Data (forex, metals, crypto, indices, stocks) — https://twelvedata.com
TWELVEDATA_API_KEY=
# Finnhub (US stocks, secondary) — https://finnhub.io
FINNHUB_API_KEY=
MARKET_CACHE_TTL=12

# --- Trade execution ---
# BROKER=paper  -> built-in simulated broker (safe default, no real money).
# BROKER=alpaca -> real Alpaca API (US stocks + crypto). Paper endpoint below.
# BROKER=oanda  -> real OANDA v20 (forex + metals + major indices). Practice by default.
# BROKER=router -> run BOTH at once: forex/metals/indices->OANDA, stocks/crypto->Alpaca,
#                  anything else->paper. Each venue uses its own keys below.
BROKER=paper
PAPER_STARTING_BALANCE=100000

# Alpaca (stocks + crypto) — only point ALPACA_BASE_URL at the live host for real money.
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# OANDA (forex + metals) — get a token + account id at https://www.oanda.com
# OANDA_ENVIRONMENT=practice uses the demo account; =live trades real money.
OANDA_API_TOKEN=
OANDA_ACCOUNT_ID=
OANDA_ENVIRONMENT=practice

# --- Stripe (international cards) ---
STRIPE_SECRET_KEY=sk_test_XXXXXXXXXXXX
STRIPE_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXX
# Create these in Stripe dashboard (Products) and paste the price_ IDs:
STRIPE_PRICE_TRADER=price_XXXXXXXXXXXX
STRIPE_PRICE_ELITE=price_XXXXXXXXXXXX

# --- Flutterwave (African mobile money) ---
FLW_SECRET_KEY=FLWSECK_TEST-XXXXXXXXXXXX
FLW_PUBLIC_KEY=FLWPUBK_TEST-XXXXXXXXXXXX
FLW_ENCRYPTION_KEY=FLWSECK_TEST-XXXXXXXXXXXX
FLW_WEBHOOK_HASH=your-self-generated-webhook-secret-string

# --- FX rate (USD -> ZMW) ---
USD_TO_ZMW_RATE=26.5
